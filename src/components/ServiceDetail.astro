---
import PageHero from './PageHero.astro';
import SectionHeading from './SectionHeading.astro';
import CtaBand from './CtaBand.astro';
import Icon from './Icon.astro';
import { services, type Service } from '../data/services';
import { brandBySlug } from '../data/brands';
import { galleryImages } from '../data/gallery';
import { process as steps } from '../data/content';
import { site, telLink, whatsappFor } from '../data/site';

interface Props { service: Service; }
const { service } = Astro.props;

const partners = service.brandSlugs.map(brandBySlug).filter(Boolean);
const shots = galleryImages.filter((g) => g.category === service.galleryKey).slice(0, 6);
const others = services.filter((s) => s.slug !== service.slug);
const waLink = whatsappFor(service.name);
---
<PageHero
  eyebrow={service.heroEyebrow}
  title={service.heroTitle}
  subtitle={service.heroLead}
  image={service.feature}
  crumb={service.name}
  primary={{ href: '/contact-us', label: 'Book your visit Now' }}
  secondary={{ href: telLink, label: `Call ${site.phoneDisplay}` }}
/>

<!-- Intro + benefits -->
<section class="py-16 md:py-24">
  <div class="container-mcp grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
    <div class="lg:col-span-7 fade-in">
      <span class="eyebrow mb-5">{service.name}</span>
      <h2 class="heading-lg text-balance mb-6">{service.heroTitle}</h2>
      {service.intro.map((p) => <p class="text-lg text-muted leading-relaxed mb-5 text-pretty">{p}</p>)}
      <div class="flex flex-col sm:flex-row gap-3 mt-8">
        <a href="/contact-us" class="btn btn-primary btn-lg">Book your visit Now <Icon name="ArrowRight" size={16} strokeWidth={2.5} /></a>
        <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg"><Icon name="MessageCircle" size={18} strokeWidth={2.2} /> WhatsApp</a>
      </div>
    </div>
    <div class="lg:col-span-5 fade-in stagger-2">
      <div class="card-feature">
        <h3 class="heading-md mb-5">Why choose us for this</h3>
        <ul class="space-y-3.5">
          {service.benefits.map((b) => (
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red/10 text-red-deep flex-shrink-0 mt-0.5"><Icon name="Check" size={14} strokeWidth={3} /></span>
              <span class="text-navy font-medium">{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- What's included -->
<section class="py-16 md:py-24 section-snow">
  <div class="container-mcp">
    <SectionHeading eyebrow="What's included" title={`Our ${service.name.toLowerCase()} service`} intro="Every job is finished to a professional, accredited standard - with honest advice on what suits you and your budget." align="center" />
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
      {service.includes.map((inc, i) => (
        <div class={`card-feature fade-in stagger-${(i % 4) + 1}`}>
          <span class="tile-icon tile-icon-red mb-4"><Icon name={service.icon} size={22} strokeWidth={2} /></span>
          <h3 class="font-display font-bold text-navy text-lg mb-2">{inc.title}</h3>
          <p class="text-muted text-[0.93rem] leading-relaxed">{inc.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{partners.length > 0 && (
  <section class="py-14 md:py-20">
    <div class="container-mcp">
      <SectionHeading eyebrow="Brand-partner accredited" title="Premium brands we fit" align="center" />
      <div class="flex flex-wrap justify-center items-center gap-3 md:gap-4 mt-10">
        {partners.map((b) => (
          <div class="brand-logo" style="width: 150px; height: 84px;" title={b!.blurb}>
            <img src={b!.logo} alt={b!.name} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{shots.length > 0 && (
  <section class="py-16 md:py-24 section-snow">
    <div class="container-mcp">
      <SectionHeading
        eyebrow="Recent work"
        title={`${service.name} gallery`}
        align="left"
        ctaHref="/gallery"
        ctaLabel="View full gallery"
      />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mt-10">
        {shots.map((s, i) => (
          <a href="/gallery" class={`gal-shot fade-in stagger-${(i % 3) + 1}`}>
            <img src={s.src} alt={s.alt} loading="lazy" width="500" height="375" />
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Process -->
<section class="py-16 md:py-24">
  <div class="container-mcp">
    <SectionHeading eyebrow="How it works" title="From enquiry to drive-away" align="center" />
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
      {steps.map((s, i) => (
        <div class={`relative fade-in stagger-${(i % 4) + 1}`}>
          <span class="font-mono text-5xl font-bold text-red/15">{s.step}</span>
          <h3 class="font-display font-bold text-navy text-lg mt-2 mb-2">{s.title}</h3>
          <p class="text-muted text-[0.93rem] leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Other services -->
<section class="py-16 md:py-20 section-stone">
  <div class="container-mcp">
    <SectionHeading eyebrow="More from TJ Mods" title="Explore our other services" align="center" />
    <div class="flex flex-wrap justify-center gap-2.5 mt-10">
      {others.map((s) => (
        <a href={`/services/${s.slug}`} class="tag !py-2.5 !px-4">
          <Icon name={s.icon} size={16} strokeWidth={2} />
          {s.name}
        </a>
      ))}
    </div>
  </div>
</section>

<CtaBand />

<style>
  .gal-shot { position: relative; display: block; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgb(var(--rgb-border)); aspect-ratio: 4/3; background: #0F0F0F; }
  .gal-shot img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.4,0,0.2,1); }
  .gal-shot:hover img { transform: scale(1.06); }
</style>
