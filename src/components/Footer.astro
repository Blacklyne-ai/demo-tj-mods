---
import { site, nav, legalNav, telLink, mailLink, whatsappLink } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const year = 2026;
---
<footer class="section-navy relative overflow-hidden pt-16 md:pt-20 pb-8">
  <div class="glow-orb" style="width: 460px; height: 460px; top: -160px; right: -120px; background: #D71E28; opacity: 0.12;"></div>
  <div class="container-mcp relative">
    <div class="grid gap-10 md:gap-8 md:grid-cols-12 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-flex items-center justify-center rounded-2xl bg-white p-1.5">
            <img src="/logo.png" alt="TJ Mods" width="90" height="72" class="h-12 w-auto" />
          </span>
          <span class="font-display text-2xl font-extrabold tracking-tight text-white leading-none">
            <span class="text-red-bright">TJ</span> MODS
          </span>
        </div>
        <p class="text-white/60 text-[0.95rem] leading-relaxed mb-5 max-w-sm">
          {site.tagline}. {site.stats.yearsExperience}+ years of window tinting, wrapping, PPF, parking sensors, audio, lighting &amp; security - all under one roof in Ilford.
        </p>
        <div class="flex items-center gap-2.5">
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="TJ Mods on Facebook" class="social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.08 24 18.09 24 12.07Z"/></svg>
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="TJ Mods on Instagram" class="social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.95c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.4-.55.22-.94.47-1.35.88-.41.41-.66.8-.88 1.35-.16.42-.35 1.04-.4 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.4 2.19.22.55.47.94.88 1.35.41.41.8.66 1.35.88.42.16 1.04.35 2.19.4 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.4.55-.22.94-.47 1.35-.88.41-.41.66-.8.88-1.35.16-.42.35-1.04.4-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.4-2.19-.22-.55-.47-.94-.88-1.35-.41-.41-.8-.66-1.35-.88-.42-.16-1.04-.35-2.19-.4-1.24-.06-1.61-.07-4.76-.07Zm0 3.32a4.57 4.57 0 1 0 0 9.14 4.57 4.57 0 0 0 0-9.14Zm0 7.54a2.97 2.97 0 1 1 0-5.94 2.97 2.97 0 0 1 0 5.94Zm5.82-7.74a1.07 1.07 0 1 1-2.14 0 1.07 1.07 0 0 1 2.14 0Z"/></svg>
          </a>
          <a href={site.social.twitter} target="_blank" rel="noopener" aria-label="TJ Mods on Twitter / X" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 1.5h3.68l-8.04 9.19L24 22.5h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.5h7.59l5.24 6.93L18.9 1.5Zm-1.29 18.8h2.04L6.48 3.6H4.29l13.32 16.7Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h3 class="footer-h">Our Services</h3>
        <ul class="space-y-2.5">
          {services.map((s) => (
            <li><a href={`/services/${s.slug}`} class="nav-link text-white/60 hover:text-white text-[0.92rem]">{s.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-2">
        <h3 class="footer-h">Company</h3>
        <ul class="space-y-2.5">
          {nav.filter((n) => n.href !== '/').map((n) => (
            <li><a href={n.href} class="nav-link text-white/60 hover:text-white text-[0.92rem]">{n.label}</a></li>
          ))}
          <li><a href="/services" class="nav-link text-white/60 hover:text-white text-[0.92rem]">All Services</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <h3 class="footer-h">Visit TJ Mods</h3>
        <ul class="space-y-3.5 text-[0.92rem]">
          <li class="flex gap-3 text-white/60">
            <Icon name="MapPin" size={17} strokeWidth={2} class="text-red-bright flex-shrink-0 mt-0.5" />
            <span>{site.address.street}, {site.address.area}<br />{site.address.postcode}</span>
          </li>
          <li>
            <a href={telLink} class="flex gap-3 text-white/60 hover:text-white transition">
              <Icon name="Phone" size={17} strokeWidth={2} class="text-red-bright flex-shrink-0" />
              <span class="mono">{site.phoneDisplay}</span>
            </a>
          </li>
          <li>
            <a href={mailLink} class="flex gap-3 text-white/60 hover:text-white transition">
              <Icon name="Mail" size={17} strokeWidth={2} class="text-red-bright flex-shrink-0" />
              <span>{site.email}</span>
            </a>
          </li>
          <li class="flex gap-3 text-white/60">
            <Icon name="Clock" size={17} strokeWidth={2} class="text-red-bright flex-shrink-0 mt-0.5" />
            <span>Mon - Sat: 9am - 5pm<br />Sunday: Closed</span>
          </li>
        </ul>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm mt-4">
          <Icon name="MessageCircle" size={15} strokeWidth={2.2} /> WhatsApp us
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-7 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-white/45 text-[0.82rem] leading-relaxed">
        © {year} {site.legalName} (trading as {site.name}). All rights reserved.<br class="hidden md:block" />
        <span class="text-white/35">{site.legalName} is registered in England &amp; Wales. {site.address.street}, {site.address.area}, {site.address.postcode}.</span>
      </p>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {legalNav.map((l) => (
          <li><a href={l.href} class="text-white/50 hover:text-white text-[0.82rem] transition">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer-h { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; margin-bottom: 1.1rem; }
  .social-btn {
    display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px;
    border-radius: 12px; color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .social-btn:hover { transform: translateY(-3px); color: #fff; background: linear-gradient(180deg,#E63946,#D71E28); border-color: rgba(255,255,255,0.25); }
</style>
