---
// Editorial section header — numbered eyebrow + balanced headline + optional intro.
// Replaces the old centred-and-decorative SectionHeading for the homepage's
// magazine-style narrative.
import Icon from './Icon.astro';
interface Props {
  num: string;          // "01", "02" ...
  kicker: string;       // category label, e.g. "Services"
  title: string;        // the big headline
  intro?: string;
  align?: 'left' | 'center';
  light?: boolean;
  ctaHref?: string;
  ctaLabel?: string;
}
const { num, kicker, title, intro, align = 'left', light = false, ctaHref, ctaLabel } = Astro.props;
const center = align === 'center';
---
<div class={`${ctaHref ? 'flex flex-col md:flex-row md:items-end md:justify-between gap-8' : ''} fade-in`}>
  <div class={center ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}>
    <p class={`section-eyebrow ${light ? 'section-eyebrow-light' : ''} ${center ? 'justify-center' : ''}`}>
      <span class="section-eyebrow-num">§ {num}</span>
      {kicker}
    </p>
    <h2 class={`text-balance ${light ? 'text-white' : ''}`} style="font-size: clamp(2rem, 4.5vw, 3.4rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; margin: 0;">{title}</h2>
    {intro && <p class={`mt-5 text-lg leading-relaxed text-pretty ${light ? 'text-white/70' : 'text-muted'} ${center ? 'mx-auto' : ''}`} style="max-width: 38rem;">{intro}</p>}
  </div>
  {ctaHref && ctaLabel && (
    <a href={ctaHref} class={`btn ${light ? 'btn-light' : 'btn-outline'} flex-shrink-0 self-start md:self-end`}>
      {ctaLabel}
      <Icon name="ArrowRight" size={14} strokeWidth={2.4} />
    </a>
  )}
</div>

<style>
  .section-eyebrow.justify-center::after { display: none; }
  .section-eyebrow.justify-center { justify-content: center; }
</style>
