---
import { site, telLink, whatsappLink } from '../data/site';
import Icon from './Icon.astro';
---
<!-- Mobile edge bar — flush to viewport bottom, hairline divisions, mono labels -->
<div class="floating-mobile" role="region" aria-label="Quick contact">
  <a href={telLink} class="fm-cell" aria-label={`Call TJ Mods on ${site.phoneDisplay}`}>
    <Icon name="Phone" size={15} strokeWidth={2} class="text-red-bright" />
    <span class="fm-label">Call</span>
  </a>
  <a href={whatsappLink} target="_blank" rel="noopener" class="fm-cell" aria-label="Message TJ Mods on WhatsApp">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:#23c971"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.92.5 3.79 1.46 5.44L2 22l4.78-1.25a9.93 9.93 0 0 0 5.26 1.51h.01c5.47 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01A9.86 9.86 0 0 0 12.04 2Zm0 18.17a8.21 8.21 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.4c0-4.55 3.7-8.25 8.25-8.25 2.2 0 4.27.86 5.83 2.42a8.2 8.2 0 0 1 2.42 5.83c0 4.55-3.7 8.26-8.26 8.26Zm4.5-6.2c-.25-.12-1.46-.72-1.69-.8-.23-.08-.39-.12-.55.12-.16.25-.63.8-.78.97-.14.16-.29.18-.54.06-.25-.12-1.04-.38-1.98-1.22-.73-.65-1.22-1.45-1.37-1.7-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.55-1.34-.76-1.83-.2-.48-.4-.41-.55-.42h-.47c-.16 0-.43.06-.65.31-.22.25-.85.83-.85 2.02 0 1.19.87 2.35.99 2.51.12.16 1.71 2.61 4.15 3.66.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.46-.6 1.66-1.17.2-.58.2-1.07.14-1.17-.06-.1-.22-.16-.47-.28Z"/></svg>
    <span class="fm-label">WhatsApp</span>
  </a>
  <a href={site.address.directionsUrl} target="_blank" rel="noopener" class="fm-cell" aria-label="Get directions to TJ Mods">
    <Icon name="Navigation" size={15} strokeWidth={2} class="text-navy" />
    <span class="fm-label">Directions</span>
  </a>
</div>

<style>
  .floating-mobile {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    gap: 0; padding: 0;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(16px) saturate(160%); -webkit-backdrop-filter: blur(16px) saturate(160%);
    border-top: 1px solid rgba(15,15,15,0.1);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .fm-cell {
    flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 0.55rem;
    padding: 0.85rem 0.3rem; color: rgb(var(--rgb-navy));
    font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; line-height: 1;
    transition: background 0.2s ease;
    border-right: 1px solid rgba(15,15,15,0.08);
  }
  .fm-cell:last-child { border-right: 0; }
  .fm-cell:active { background: rgba(215,30,40,0.06); }
  .fm-label { line-height: 1; }
</style>
