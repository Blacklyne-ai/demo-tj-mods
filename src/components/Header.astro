---
import { telLink, site } from '../data/site';
import Icon from './Icon.astro';
import OverlayMenu from './OverlayMenu.astro';
const { current = '' } = Astro.props;
---
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-400" style="background: transparent;">
  <div class="px-5 md:px-10 lg:px-12">
    <div class="flex items-center justify-between h-20 md:h-24" id="hdr-row">
      <!-- LOGO — minimal mark only, no wordmark slab -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0" aria-label={`${site.name} — home`}>
        <img src="/logo.png" alt="TJ Mods" width="120" height="96" class="h-9 md:h-11 w-auto" />
        <span class="hidden md:flex flex-col leading-none border-l border-navy/15 pl-3 hdr-meta">
          <span class="text-[0.6rem] uppercase tracking-[0.2em] font-mono text-muted">EST. {site.stats.sinceYear}</span>
          <span class="text-[0.6rem] uppercase tracking-[0.2em] font-mono text-muted mt-1">Ilford · E. London</span>
        </span>
      </a>

      <!-- RIGHT — minimal: live status, phone hairline link, MENU trigger -->
      <div class="flex items-center gap-4 md:gap-7">
        <span class="hidden xl:inline-flex items-center gap-2 font-mono text-[0.68rem] uppercase tracking-[0.16em] hdr-status">
          <span class="status-dot status-dot-closed js-hdr-dot"></span>
          <span class="js-hdr-status">Hours</span>
        </span>

        <a href={telLink} class="hidden sm:inline-flex items-baseline gap-2 font-mono text-sm hdr-phone group" aria-label={`Call TJ Mods on ${site.phoneDisplay}`}>
          <span class="text-[0.6rem] uppercase tracking-[0.2em] text-muted group-hover:text-red-deep transition">CALL</span>
          <span class="text-navy group-hover:text-red-deep transition">{site.phoneDisplay}</span>
        </a>

        <button id="menu-trigger" class="menu-trigger" aria-label="Open menu" aria-expanded="false" aria-controls="overlay-menu">
          <span class="menu-lines" aria-hidden="true"><span></span><span></span></span>
          <span class="menu-label">Menu</span>
        </button>
      </div>
    </div>
  </div>

  <div class="hdr-hairline" aria-hidden="true"></div>
</header>

<OverlayMenu current={current} />

<style>
  /* The header at top of page: transparent. After scroll: solid white with hairline. */
  #site-header.is-scrolled { background: rgba(255,255,255,0.94); backdrop-filter: blur(14px) saturate(160%); -webkit-backdrop-filter: blur(14px) saturate(160%); }
  #site-header.is-scrolled .hdr-hairline { background: rgb(15 15 15 / 0.1); }
  .hdr-hairline { position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: transparent; transition: background 0.4s ease; }

  /* On dark hero (page top, unscrolled): logo+text are LIGHT */
  #site-header:not(.is-scrolled) .hdr-meta span { color: rgb(255 255 255 / 0.55); }
  #site-header:not(.is-scrolled) .hdr-meta { border-left-color: rgb(255 255 255 / 0.16); }
  #site-header:not(.is-scrolled) .hdr-phone .text-muted { color: rgb(255 255 255 / 0.55); }
  #site-header:not(.is-scrolled) .hdr-phone .text-navy { color: #fff; }
  #site-header:not(.is-scrolled) .hdr-status { color: rgb(255 255 255 / 0.6); }
  #site-header:not(.is-scrolled) .menu-trigger { color: #fff; border-color: rgb(255 255 255 / 0.25); }
  #site-header:not(.is-scrolled) .menu-trigger .menu-lines span { background: #fff; }

  /* MENU trigger — minimal pill: two lines + "Menu" label */
  .menu-trigger {
    display: inline-flex; align-items: center; gap: 0.7rem;
    padding: 0.55rem 1.1rem 0.55rem 0.85rem; border-radius: 999px;
    border: 1px solid rgb(15 15 15 / 0.16); background: transparent;
    color: rgb(var(--rgb-navy)); cursor: pointer;
    transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .menu-trigger:hover { border-color: rgb(var(--rgb-red)); color: rgb(var(--rgb-red-deep)); }
  .menu-lines { display: inline-flex; flex-direction: column; gap: 4px; }
  .menu-lines span { display: block; width: 18px; height: 1.5px; background: rgb(var(--rgb-navy)); transition: background 0.3s ease, transform 0.3s ease, width 0.3s ease; }
  .menu-trigger:hover .menu-lines span { background: rgb(var(--rgb-red)); }
  .menu-trigger:hover .menu-lines span:last-child { width: 12px; }
  .menu-label { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; line-height: 1; }
</style>

<script>
  const hdr = document.getElementById('site-header');
  const trigger = document.getElementById('menu-trigger');
  const overlay = document.getElementById('overlay-menu');
  const closeBtn = document.getElementById('overlay-close');

  // scroll → switch header from transparent (over hero) to solid (after scroll)
  let ticking = false;
  function onScroll() {
    if (!hdr) return;
    if (window.scrollY > 60) hdr.classList.add('is-scrolled');
    else hdr.classList.remove('is-scrolled');
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
  }, { passive: true });
  onScroll();

  // Overlay open/close
  function openMenu() {
    overlay?.classList.add('is-open');
    document.body.classList.add('overlay-open');
    trigger?.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    overlay?.classList.remove('is-open');
    document.body.classList.remove('overlay-open');
    trigger?.setAttribute('aria-expanded', 'false');
  }
  trigger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeMenu(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && overlay?.classList.contains('is-open')) closeMenu(); });
  // close on nav-click (so anchors work)
  overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

  // Live status (same logic, just bound to .js-hdr-* in the minimal bar)
  const DAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  function updateStatus() {
    const now = new Date();
    const day = now.getDay();
    const mins = now.getHours() * 60 + now.getMinutes();
    const workday = day >= 1 && day <= 6;
    const open = workday && mins >= 540 && mins < 1020;
    let label: string;
    if (open) label = 'Open · Closes 5pm';
    else if (workday && mins < 540) label = 'Closed · Opens 9am';
    else {
      let nd = (day + 1) % 7; for (let i = 0; i < 7 && !(nd >= 1 && nd <= 6); i++) nd = (nd + 1) % 7;
      label = `Closed · Opens ${DAYS[nd]} 9am`;
    }
    document.querySelectorAll('.js-hdr-dot').forEach((d) => { d.className = 'status-dot js-hdr-dot ' + (open ? 'status-dot-open' : 'status-dot-closed'); });
    document.querySelectorAll('.js-hdr-status').forEach((t) => { t.textContent = label; });
  }
  updateStatus();
  setInterval(updateStatus, 60000);
</script>
