---
import { nav, telLink, whatsappLink, site } from '../data/site';
import type { NavItem } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;

const isActive = (item: NavItem) =>
  current === item.href || (item.href !== '/' && current.startsWith(item.href));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="container-mcp pt-4 md:pt-6">
    <div
      id="nav-shell"
      class="flex items-center justify-between gap-3 pl-3 pr-3 md:pl-4 md:pr-3 py-2 rounded-pill transition-all duration-500"
      style="background: rgba(255,255,255,0.82); backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%); border: 1px solid rgba(15,15,15,0.09); box-shadow: 0 1px 2px rgba(8,8,8,0.04), 0 8px 32px -8px rgba(15,15,15,0.16), inset 0 1px 0 0 rgba(255,255,255,0.7);"
    >
      <!-- Logo: original TJ Mods crest (contains the wordmark) -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0" aria-label={`${site.name} — home`}>
        <img src="/logo.png" alt="TJ Mods" width="120" height="96" class="h-10 md:h-12 w-auto" />
        <span class="hidden xl:flex flex-col leading-none border-l border-navy/15 pl-3">
          <span class="text-[0.6rem] uppercase tracking-[0.2em] text-muted font-mono">Est. 2010</span>
          <span class="text-[0.6rem] uppercase tracking-[0.2em] text-muted font-mono mt-1">Ilford · E. London</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Primary">
        {nav.map((item) =>
          item.mega === 'services' ? (
            <div class="nav-dd nav-mega relative">
              <a href={item.href} class={`nav-pill inline-flex items-center gap-1 ${isActive(item) ? 'active' : ''}`} aria-haspopup="true" aria-expanded="false">
                {item.label}
                <Icon name="ChevronDown" size={14} strokeWidth={2.4} class="nav-dd-chev" />
              </a>
              <div class="nav-mega-panel" role="menu">
                <p class="nav-mega-title">7 services under one roof</p>
                <div class="nav-mega-grid">
                  {services.map((s) => (
                    <a href={`/services/${s.slug}`} role="menuitem" class="nav-mega-item">
                      <span class="nav-mega-ico"><Icon name={s.icon} size={18} strokeWidth={2} /></span>
                      <span class="nav-mega-label">{s.name}</span>
                    </a>
                  ))}
                </div>
                <a href="/services" class="nav-mega-all">
                  View all services
                  <Icon name="ArrowRight" size={14} strokeWidth={2.4} />
                </a>
              </div>
            </div>
          ) : (
            <a href={item.href} class={`nav-pill ${isActive(item) ? 'active' : ''}`}>{item.label}</a>
          )
        )}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-2">
        <!-- Live opening-hours status (styled CSS dot, no emoji) -->
        <span class="status-chip hidden xl:inline-flex" title="Opening hours · Mon to Sat, 9am to 5pm">
          <span class="status-dot status-dot-closed js-dot"></span>
          <span class="js-status-text">Opening hours</span>
        </span>

        <a href={telLink} class="btn btn-primary btn-sm hidden lg:inline-flex whitespace-nowrap" aria-label={`Call TJ Mods on ${site.phoneDisplay}`}>
          <Icon name="Phone" size={14} strokeWidth={2.3} />
          <span class="hidden 2xl:inline">Book now</span>
          <span class="mono">{site.phoneDisplay}</span>
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm !px-3 hidden sm:inline-flex" aria-label="Message TJ Mods on WhatsApp">
          <Icon name="MessageCircle" size={16} strokeWidth={2.2} />
        </a>

        <button id="menu-toggle" class="lg:hidden p-2.5 rounded-full transition" style="color: #0F0F0F;" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-2 mx-4 rounded-3xl overflow-hidden" style="background: rgba(255,255,255,0.98); backdrop-filter: blur(22px); border: 1px solid rgba(15,15,15,0.10); box-shadow: 0 30px 60px -20px rgba(8,8,8,0.32); max-height: calc(100vh - 7rem); overflow-y: auto;">
    <nav class="flex flex-col p-4" aria-label="Mobile">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href} class="py-3 px-2 text-ink/85 hover:text-ink border-b border-navy/10 font-semibold transition" style={current === item.href ? 'color:#A8121C' : ''}>{item.label}</a>
          {item.mega === 'services' && (
            <div class="grid grid-cols-2 gap-1 py-3 border-b border-navy/10">
              {services.map((s) => (
                <a href={`/services/${s.slug}`} class="flex items-center gap-2 text-[0.82rem] text-muted hover:text-red-deep py-2 px-1.5 transition">
                  <Icon name={s.icon} size={16} strokeWidth={2} />
                  {s.name}
                </a>
              ))}
            </div>
          )}
        </Fragment>
      ))}
      <span class="status-chip self-start mt-4 mb-1">
        <span class="status-dot status-dot-closed js-dot"></span>
        <span class="js-status-text">Opening hours</span>
      </span>
      <a href={telLink} class="btn btn-primary btn-block mt-3">
        <Icon name="Phone" size={16} strokeWidth={2.3} /> Book now · {site.phoneDisplay}
      </a>
      <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-block mt-2">
        <Icon name="MessageCircle" size={16} strokeWidth={2.2} /> WhatsApp us
      </a>
    </nav>
  </div>
</header>

<style>
  .hamburger { display: inline-flex; flex-direction: column; justify-content: center; gap: 4px; width: 22px; height: 22px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: #D71E28; border-radius: 2px; transition: transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55), opacity 0.25s ease; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .status-chip {
    align-items: center; gap: 0.45rem; padding: 0.35rem 0.75rem; border-radius: 999px;
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.02em; font-family: var(--font-mono);
    background: rgba(15,15,15,0.04); border: 1px solid rgba(15,15,15,0.1); color: rgba(15,15,15,0.78); white-space: nowrap;
  }

  /* services mega panel */
  .nav-mega-panel {
    position: absolute; top: calc(100% + 10px); left: 50%; transform: translateX(-50%) translateY(8px);
    width: 30rem; padding: 1.1rem; border-radius: 22px;
    background: rgba(255,255,255,0.98); border: 1px solid rgba(15,15,15,0.1);
    backdrop-filter: blur(22px) saturate(170%); -webkit-backdrop-filter: blur(22px) saturate(170%);
    box-shadow: 0 28px 60px -20px rgba(8,8,8,0.34), inset 0 1px 0 0 rgba(255,255,255,0.7);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease, transform 0.25s ease; z-index: 60;
  }
  .nav-mega:hover .nav-mega-panel, .nav-mega:focus-within .nav-mega-panel { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav-mega:hover .nav-dd-chev { transform: rotate(180deg); }
  .nav-mega-title { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.2em; font-family: var(--font-mono); color: var(--c-muted); margin: 0 0 0.7rem 0.3rem; }
  .nav-mega-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.2rem; }
  .nav-mega-item { display: inline-flex; align-items: center; gap: 0.65rem; padding: 0.6rem 0.65rem; border-radius: 12px; font-size: 0.88rem; font-weight: 600; color: rgba(15,15,15,0.82); transition: background 0.2s ease, color 0.2s ease; }
  .nav-mega-item:hover { background: rgba(215,30,40,0.07); color: #A8121C; }
  .nav-mega-ico { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 10px; background: linear-gradient(180deg,#1A1A1A,#0F0F0F); color: #fff; flex-shrink: 0; }
  .nav-mega-item:hover .nav-mega-ico { background: #D71E28; }
  .nav-mega-all { display: inline-flex; align-items: center; gap: 0.4rem; margin: 0.85rem 0.3rem 0.1rem; font-size: 0.82rem; font-weight: 700; color: #A8121C; }
  .nav-mega-all svg { transition: transform 0.3s ease; }
  .nav-mega-all:hover svg { transform: translateX(4px); }
  .nav-dd-chev { transition: transform 0.3s ease; }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const shell = document.getElementById('nav-shell');
  const burger = toggle?.querySelector('.hamburger');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    burger?.classList.toggle('open', !isOpen);
    toggle?.setAttribute('aria-expanded', (!isOpen).toString());
    toggle?.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      burger?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  // Nav strengthen / shrink on scroll
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      if (shell) {
        if (y > 30) { shell.style.background = 'rgba(255,255,255,0.94)'; shell.style.transform = 'scale(0.985)'; }
        else { shell.style.background = 'rgba(255,255,255,0.82)'; shell.style.transform = 'scale(1)'; }
      }
      ticking = false;
    });
  });

  // ── Live opening-hours status — Mon–Sat 9:00–17:00, Sunday closed.
  // Styled CSS dots only (no emoji). Updates on load + every 60s.
  const DAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  function nextOpenLabel(day: number) {
    // returns the next day name we open (Mon–Sat). If today still to open, "today".
    let d = day;
    for (let i = 0; i < 7; i++) {
      if (d >= 1 && d <= 6) return DAYS[d];
      d = (d + 1) % 7;
    }
    return 'Monday';
  }
  function updateStatus() {
    const now = new Date();
    const day = now.getDay(); // 0 Sun … 6 Sat
    const mins = now.getHours() * 60 + now.getMinutes();
    const isWorkday = day >= 1 && day <= 6;
    const open = isWorkday && mins >= 540 && mins < 1020; // 9:00–17:00

    let label: string;
    if (open) {
      label = 'Open now · Closes 5pm';
    } else if (isWorkday && mins < 540) {
      label = 'Closed · Opens 9am';
    } else {
      // after hours today, or Sunday → next working day
      let nd = (day + 1) % 7;
      if (isWorkday && mins < 540) nd = day;
      const name = nextOpenLabel(nd);
      label = `Closed · Opens ${name} 9am`;
    }
    document.querySelectorAll('.js-dot').forEach((d) => {
      d.className = 'status-dot js-dot ' + (open ? 'status-dot-open' : 'status-dot-closed');
    });
    document.querySelectorAll('.js-status-text').forEach((t) => { t.textContent = label; });
  }
  updateStatus();
  setInterval(updateStatus, 60000);
</script>
