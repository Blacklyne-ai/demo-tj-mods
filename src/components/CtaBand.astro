---
import Icon from './Icon.astro';
import { site, telLink, whatsappLink } from '../data/site';
interface Props { title?: string; text?: string; }
const {
  title = 'Ready to modify your car?',
  text = 'Call, message us on WhatsApp, or drop in to our Ilford garage to see our range of colours and films in person. No-obligation quotes on every service.',
} = Astro.props;
---
<section class="section-navy py-20 md:py-24 relative overflow-hidden">
  <div class="glow-orb" style="width: 420px; height: 420px; top: -120px; right: -80px; background: #D71E28; opacity: 0.18;"></div>
  <div class="glow-orb" style="width: 360px; height: 360px; bottom: -140px; left: -90px; background: #949CA8; opacity: 0.22;"></div>
  <div class="container-mcp relative">
    <div class="max-w-3xl fade-in">
      <span class="eyebrow eyebrow-light mb-5">Book your visit now</span>
      <h2 class="heading-lg text-white text-balance mb-5">{title}</h2>
      <p class="text-lg text-white/70 leading-relaxed mb-8 max-w-2xl text-pretty">{text}</p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-3">
        <a href={telLink} class="btn btn-primary btn-lg">
          <Icon name="Phone" size={17} strokeWidth={2.3} />
          {site.phoneDisplay}
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
          <Icon name="MessageCircle" size={18} strokeWidth={2.2} />
          WhatsApp
        </a>
        <a href="/contact-us" class="btn btn-light btn-lg">
          Find us
          <Icon name="ArrowRight" size={16} strokeWidth={2.5} />
        </a>
      </div>
      <p class="text-sm text-white/45 mt-6 flex flex-wrap items-center gap-x-2 gap-y-1">
        <Icon name="MapPin" size={15} strokeWidth={2} />
        {site.address.street}, {site.address.area} {site.address.postcode}
        <span class="opacity-40">·</span>
        Mon - Sat, 9am - 5pm
      </p>
    </div>
  </div>
</section>
