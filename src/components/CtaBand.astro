---
import Icon from './Icon.astro';
import { site, telLink, whatsappLink } from '../data/site';
interface Props { title?: string; text?: string; }
const {
  title = 'Ready to modify your car?',
  text = 'Call, message us on WhatsApp, or drop in to our Ilford garage to see our range of colours and films in person. No-obligation quotes on every service.',
} = Astro.props;
---
<section class="section-navy py-24 md:py-36 relative overflow-hidden">
  <div class="container-mcp relative">
    <div class="grid lg:grid-cols-12 gap-10 items-end fade-in">
      <div class="lg:col-span-7">
        <p class="section-eyebrow section-eyebrow-light"><span class="section-eyebrow-num">§</span> Book your visit</p>
        <h2 class="text-white text-balance" style="font-size: clamp(2.2rem, 5.5vw, 4.4rem); font-weight: 700; line-height: 1.04; letter-spacing: -0.035em; margin: 0;">{title}</h2>
        <p class="text-lg text-white/65 leading-relaxed mt-6 max-w-xl text-pretty">{text}</p>
      </div>
      <div class="lg:col-span-5">
        <ul class="space-y-5">
          <li>
            <a href={telLink} class="cta-row group">
              <span class="cta-mono">01 · Call</span>
              <span class="cta-big">{site.phoneDisplay}</span>
              <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener" class="cta-row group">
              <span class="cta-mono">02 · Message</span>
              <span class="cta-big">WhatsApp us</span>
              <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a href="/contact-us" class="cta-row group">
              <span class="cta-mono">03 · Visit</span>
              <span class="cta-big">{site.address.street}, {site.address.postcode}</span>
              <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-row {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: baseline; gap: 1.25rem;
    padding: 1.4rem 0; border-top: 1px solid rgb(255 255 255 / 0.12);
    color: #fff; transition: padding 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .cta-row:hover { padding-left: 0.5rem; padding-right: 0; }
  ul li:last-child .cta-row { border-bottom: 1px solid rgb(255 255 255 / 0.12); }
  .cta-mono {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgb(255 255 255 / 0.45); width: 5.5rem; flex-shrink: 0;
  }
  .cta-big {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(1.2rem, 2.4vw, 1.7rem); line-height: 1.15;
    color: #fff; letter-spacing: -0.015em;
    transition: color 0.3s ease;
  }
  .cta-row:hover .cta-big { color: rgb(var(--rgb-red-bright)); }
  .cta-arrow { font-size: 1.4rem; color: rgb(255 255 255 / 0.35); transition: color 0.3s ease, transform 0.3s ease; }
  .cta-row:hover .cta-arrow { color: rgb(var(--rgb-red-bright)); transform: translateX(0.4rem); }
</style>
