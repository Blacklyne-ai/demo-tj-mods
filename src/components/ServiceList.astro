---
// Editorial 2027 service hover-list.
// Left: numbered list (01-07), each row reveals a blurb on hover and slides right.
// Right (desktop): sticky image preview, swaps to the hovered service's photo.
import Icon from './Icon.astro';
import { services } from '../data/services';
---
<div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
  <!-- LIST -->
  <div class="lg:col-span-7 svc-list" data-svc-list>
    {services.map((s, i) => (
      <a
        href={`/services/${s.slug}`}
        class="svc-row"
        data-svc-slug={s.slug}
        aria-label={`${s.name} - see more`}
      >
        <span class="svc-num">0{i + 1}</span>
        <span>
          <span class="svc-name block">{s.name}</span>
          <span class="svc-blurb">{s.short}</span>
        </span>
        <span class="svc-cta">
          See more <Icon name="ArrowUpRight" size={14} strokeWidth={2.2} />
        </span>
      </a>
    ))}
  </div>

  <!-- STICKY PREVIEW (desktop only) -->
  <div class="hidden lg:block lg:col-span-5 lg:sticky lg:top-32">
    <div class="svc-preview" data-svc-preview>
      {services.map((s, i) => (
        <img
          src={s.feature}
          alt={`${s.name} by TJ Mods`}
          loading={i === 0 ? 'eager' : 'lazy'}
          class={`svc-img ${i === 0 ? 'is-active' : ''}`}
          data-svc-img={s.slug}
          width="640"
          height="800"
        />
      ))}
      <span class="svc-preview-label" data-svc-label>{services[0].name}</span>
    </div>
  </div>
</div>

<script>
  const rows = document.querySelectorAll<HTMLAnchorElement>('[data-svc-slug]');
  const imgs = document.querySelectorAll<HTMLImageElement>('[data-svc-img]');
  const label = document.querySelector<HTMLElement>('[data-svc-label]');

  function activate(slug: string, name: string) {
    imgs.forEach((im) => im.classList.toggle('is-active', im.dataset.svcImg === slug));
    if (label) label.textContent = name;
  }

  rows.forEach((row) => {
    row.addEventListener('mouseenter', () => {
      const slug = row.dataset.svcSlug || '';
      const name = row.querySelector('.svc-name')?.textContent?.trim() || '';
      activate(slug, name);
    });
    row.addEventListener('focusin', () => {
      const slug = row.dataset.svcSlug || '';
      const name = row.querySelector('.svc-name')?.textContent?.trim() || '';
      activate(slug, name);
    });
  });
</script>
