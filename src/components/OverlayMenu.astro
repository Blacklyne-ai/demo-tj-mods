---
import { nav, site, telLink, mailLink, whatsappLink } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;
---
<div id="overlay-menu" class="overlay-menu" role="dialog" aria-modal="true" aria-label="Main menu">
  <div class="overlay-menu-inner">
    <!-- top bar inside overlay (logo + close) -->
    <div class="overlay-bar">
      <a href="/" class="flex items-center gap-3" aria-label={`${site.name} — home`}>
        <img src="/logo.png" alt="TJ Mods" />
      </a>
      <button id="overlay-close" class="overlay-close" aria-label="Close menu">
        <span>Close</span>
        <span class="x-circle">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </span>
      </button>
    </div>

    <div class="overlay-grid">
      <!-- left: massive nav -->
      <nav class="overlay-nav" aria-label="Primary">
        {nav.map((item, i) => (
          <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
            <span class="nav-idx">0{i + 1}</span>
            <span class="nav-name">{item.label}</span>
            <span class="nav-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </nav>

      <!-- right: meta column -->
      <aside class="overlay-meta">
        <div>
          <h3>Call us</h3>
          <a href={telLink} class="meta-big font-mono block">{site.phoneDisplay}</a>
          <p class="meta-line text-sm mt-2">Mon - Sat, 9am - 5pm. Closed Sundays.</p>
        </div>

        <div>
          <h3>Or message</h3>
          <a href={whatsappLink} target="_blank" rel="noopener" class="meta-big block">
            WhatsApp →
          </a>
          <a href={mailLink} class="meta-line block mt-2 text-sm underline underline-offset-4 decoration-1">{site.email}</a>
        </div>

        <div>
          <h3>Visit the workshop</h3>
          <p class="meta-big">{site.address.street}<br />{site.address.area} {site.address.postcode}</p>
          <a href={site.address.directionsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-3 text-sm font-mono uppercase tracking-wider text-white/70 hover:text-white transition">
            Get directions
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 17 10-10M7 7h10v10"/></svg>
          </a>
        </div>

        <div class="flex gap-3">
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="TJ Mods on Facebook" class="overlay-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.08 24 18.09 24 12.07Z"/></svg>
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="TJ Mods on Instagram" class="overlay-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.95c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.4-.55.22-.94.47-1.35.88-.41.41-.66.8-.88 1.35-.16.42-.35 1.04-.4 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.4 2.19.22.55.47.94.88 1.35.41.41.8.66 1.35.88.42.16 1.04.35 2.19.4 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.4.55-.22.94-.47 1.35-.88.41-.41.66-.8.88-1.35.16-.42.35-1.04.4-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.4-2.19-.22-.55-.47-.94-.88-1.35-.41-.41-.8-.66-1.35-.88-.42-.16-1.04-.35-2.19-.4-1.24-.06-1.59-.07-4.76-.07Zm0 3.32a4.57 4.57 0 1 0 0 9.14 4.57 4.57 0 0 0 0-9.14Zm0 7.54a2.97 2.97 0 1 1 0-5.94 2.97 2.97 0 0 1 0 5.94Zm5.82-7.74a1.07 1.07 0 1 1-2.14 0 1.07 1.07 0 0 1 2.14 0Z"/></svg>
          </a>
          <a href={site.social.twitter} target="_blank" rel="noopener" aria-label="TJ Mods on X" class="overlay-social">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 1.5h3.68l-8.04 9.19L24 22.5h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.5h7.59l5.24 6.93L18.9 1.5Zm-1.29 18.8h2.04L6.48 3.6H4.29l13.32 16.7Z"/></svg>
          </a>
        </div>
      </aside>
    </div>

    <!-- below: 7 services as a quick-jump grid -->
    <div class="mt-12 md:mt-16">
      <h3 class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-white/45 mb-4">Our 7 services</h3>
      <div class="overlay-services">
        {services.map((s, i) => (
          <a href={`/services/${s.slug}`}>
            <span class="text-white/35 font-mono mr-1">0{i + 1}</span>
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .overlay-social {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 999px;
    color: rgb(255 255 255 / 0.7); background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.14);
    transition: all 0.3s ease;
  }
  .overlay-social:hover { color: #fff; background: rgb(var(--rgb-red)); border-color: rgb(var(--rgb-red)); }
</style>
