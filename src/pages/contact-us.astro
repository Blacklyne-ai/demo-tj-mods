---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactMethods from '../components/ContactMethods.astro';
import QuoteForm from '../components/QuoteForm.astro';
import OpeningHours from '../components/OpeningHours.astro';
import MapBlock from '../components/MapBlock.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { site, telLink, whatsappLink } from '../data/site';

const title = 'Contact TJ Mods | Car Modification Ilford East London | 0208 478 7327';
const description =
  'Contact TJ Mods in Ilford, East London. Call 0208 478 7327, WhatsApp, email info@propermods.com or visit 225 Green Lane IG1 1XR. Mon-Sat 9am-5pm.';

// Social links — Lucide has no brand icons, so we render inline SVG marks.
const socials = [
  {
    label: 'Facebook',
    handle: 'Proper Mods Essex',
    href: site.social.facebook,
    path: 'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.76 8.43-4.92 8.43-9.94Z',
  },
  {
    label: 'Instagram',
    handle: site.instagramHandle,
    href: site.social.instagram,
    path: 'M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 0 1-1.38-.9 3.72 3.72 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.5.01-4.74.07-1.14.05-1.76.24-2.18.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.42-.35 1.04-.4 2.18-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.05 1.14.24 1.76.4 2.18.21.55.47.94.88 1.35.41.41.8.67 1.35.88.42.16 1.04.35 2.18.4 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c1.14-.05 1.76-.24 2.18-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.42.35-1.04.4-2.18.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.05-1.14-.24-1.76-.4-2.18a3.63 3.63 0 0 0-.88-1.35 3.63 3.63 0 0 0-1.35-.88c-.42-.16-1.04-.35-2.18-.4-1.24-.06-1.59-.07-4.74-.07Zm0 2.76a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6Zm0 1.62a3.68 3.68 0 1 0 0 7.36 3.68 3.68 0 0 0 0-7.36Zm5.48-2.92a1.24 1.24 0 1 1 0 2.48 1.24 1.24 0 0 1 0-2.48Z',
  },
  {
    label: 'X (Twitter)',
    handle: site.instagramHandle,
    href: site.social.twitter,
    path: 'M17.53 3h3.07l-6.7 7.66L21.75 21h-5.97l-4.68-6.12L5.74 21H2.67l7.17-8.19L2.25 3h6.13l4.23 5.6L17.53 3Zm-1.08 16.17h1.7L7.62 4.74H5.8l10.65 14.43Z',
  },
];
---
<Layout title={title} description={description} current="/contact-us" ogImage="/images/gallery/window-tinting/wt-5.jpg">
  <PageHero
    eyebrow="Get in touch"
    title="Book your car in with TJ Mods"
    subtitle="Call us, message on WhatsApp, or drop into our Ilford garage to talk through your modification. We give a no-obligation quote on every service - just tell us about your car."
    image="/images/gallery/window-tinting/wt-5.jpg"
    crumb="Contact us"
    primary={{ href: telLink, label: `Call ${site.phoneDisplay}` }}
    secondary={{ href: whatsappLink, label: 'WhatsApp us' }}
  />

  <!-- Primary contact route: the four tiles -->
  <section class="py-16 md:py-24">
    <div class="container-mcp">
      <SectionHeading
        eyebrow="Talk to us"
        title="The quickest ways to reach TJ Mods"
        intro="Pick whichever suits you. We answer the phone and WhatsApp during opening hours, Monday to Saturday."
        align="center"
      />
      <div class="mt-12">
        <ContactMethods columns={4} />
      </div>
    </div>
  </section>

  <!-- Enquiry form + hours / social -->
  <section class="py-16 md:py-24 section-snow">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-start">
        <!-- LEFT: no-backend enquiry form -->
        <div class="lg:col-span-3 fade-in">
          <span class="eyebrow mb-5">Send an enquiry</span>
          <h2 class="heading-lg text-balance mb-4">Tell us about your car</h2>
          <p class="text-lg text-muted leading-relaxed mb-8 text-pretty">
            Fill in a few details and we'll get straight back to you with advice and a price. The form opens in your own email or WhatsApp - prefer to talk now? Call <a href={telLink} class="text-red-deep font-semibold underline underline-offset-2">{site.phoneDisplay}</a>.
          </p>
          <QuoteForm subject="General Enquiry" />
        </div>

        <!-- RIGHT: opening hours + social -->
        <div class="lg:col-span-2 flex flex-col gap-6 fade-in stagger-2">
          <OpeningHours />

          <div class="card-feature !p-6 md:!p-8">
            <h3 class="heading-md flex items-center gap-2.5 mb-2">
              <span class="tile-icon tile-icon-red !w-10 !h-10"><Icon name="ThumbsUp" size={18} strokeWidth={2.2} /></span>
              Follow our work
            </h3>
            <p class="text-muted text-[0.95rem] leading-relaxed mb-5">
              See real modifications from the Ilford garage and message us directly - we post our latest tints, wraps and builds on social. Find us on Instagram at <span class="font-semibold text-navy">{site.instagramHandle}</span>.
            </p>
            <ul class="flex flex-col gap-3">
              {socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener"
                    class="social-link group"
                    aria-label={`${site.name} on ${s.label}`}
                  >
                    <span class="social-mark">
                      <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor" aria-hidden="true">
                        <path d={s.path} />
                      </svg>
                    </span>
                    <span class="flex flex-col leading-tight">
                      <span class="font-display font-bold text-navy text-[0.98rem]">{s.label}</span>
                      <span class="text-muted text-sm">{s.handle}</span>
                    </span>
                    <Icon name="ArrowUpRight" size={16} strokeWidth={2.2} class="ml-auto text-muted group-hover:text-red-deep transition" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Find us — full-width map -->
  <section class="py-16 md:py-24">
    <div class="container-mcp">
      <SectionHeading
        eyebrow="Find us"
        title="Visit our garage in Ilford"
        intro="We're on Green Lane in Ilford, East London - easy to reach from across Essex and the City. Pop in to see our colours and films in person."
        align="center"
      />
      <div class="mt-12 fade-in">
        <MapBlock height="h-[460px] md:h-[520px]" />
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready when you are"
    text="Give us a call, send a quick WhatsApp, or come and see us at the Ilford garage. No-obligation quotes on window tinting, wrapping, PPF and every other service."
  />
</Layout>

<style>
  .social-link {
    display: flex; align-items: center; gap: 0.9rem;
    padding: 0.8rem 1rem; border-radius: var(--radius-md);
    border: 1px solid rgb(var(--rgb-border)); background: #fff;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .social-link:hover { transform: translateY(-2px); border-color: rgb(var(--rgb-red) / 0.5); box-shadow: var(--shadow-soft); }
  .social-mark {
    width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, #262626, #0F0F0F); color: rgb(var(--rgb-steel-light));
    border: 1px solid rgb(var(--rgb-red) / 0.3);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .social-link:hover .social-mark { color: #fff; border-color: rgb(var(--rgb-red) / 0.55); }
</style>
