---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceList from '../components/ServiceList.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import MapBlock from '../components/MapBlock.astro';
import OpeningHours from '../components/OpeningHours.astro';
import CtaBand from '../components/CtaBand.astro';
import SectionLead from '../components/SectionLead.astro';
import Icon from '../components/Icon.astro';
import { usps } from '../data/services';
import { whyChoose, stats } from '../data/content';
import { galleryPreview, galleryCategories } from '../data/gallery';
import { site, whatsappLink } from '../data/site';

const title = 'TJ Mods | Professional Car Modification East London | Window Tinting, Car Wrapping, PPF';
const description = site.description;
---
<Layout title={title} description={description} current="/" ogImage="/images/hero/slide-1.jpg">
  <Hero />

  <!-- §01 — Stats ribbon: editorial horizontal rule + tight numerics -->
  <section class="py-12 md:py-14 border-y border-line">
    <div class="container-mcp">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-8 gap-x-4">
        {stats.map((s, i) => (
          <div class={`relative ${i > 0 ? 'lg:pl-8 lg:border-l lg:border-line' : ''}`}>
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-muted mb-3">§ {String(i + 1).padStart(2, '0')}</p>
            <div class="font-display text-navy" style="font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 700; line-height: 0.95; letter-spacing: -0.035em;">
              {/^\d+$/.test(s.value)
                ? <span data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</span>
                : <span>{s.value}<span class="text-red">{s.suffix}</span></span>}
            </div>
            <p class="text-muted text-sm mt-3">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- §02 — Why TJ Mods (editorial pull-quote + USPs as numbered list) -->
  <section class="py-20 md:py-32 relative overflow-hidden">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <!-- Left rail: meta -->
        <div class="lg:col-span-3 fade-in">
          <p class="section-eyebrow"><span class="section-eyebrow-num">§ 02</span> Why TJ Mods</p>
          <p class="text-sm text-muted leading-relaxed">A professional car-modification studio in East London. Established <span class="font-mono text-navy">{site.stats.sinceYear}</span> in {site.address.area}, {site.stats.yearsExperience}+ years on Green Lane.</p>
          <div class="mt-8 flex items-center gap-4">
            <img src="/images/badge/15-years.png" alt="15 years of experience" width="56" height="56" class="h-14 w-14 object-contain" loading="lazy" />
            <div class="leading-tight">
              <span class="block font-display font-bold text-navy text-base">15+ years</span>
              <span class="block text-muted text-xs font-mono uppercase tracking-wider">Est. {site.stats.sinceYear}</span>
            </div>
          </div>
        </div>

        <!-- Centre: the editorial pull-quote (verbatim) -->
        <div class="lg:col-span-6 fade-in stagger-2">
          <h2 class="text-balance mb-8" style="font-size: clamp(1.9rem, 3.6vw, 2.9rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;">{whyChoose.heading}</h2>
          <p class="pull-quote">
            We've worked on a wide variety of cars from a <em>Mercedes Benz</em> through to an <em>Aston Martin</em>.
          </p>
          <p class="text-muted text-lg leading-relaxed mt-6 max-w-2xl text-pretty">
            We work with a variety of top class suppliers as well as some cheaper alternatives so we can service any budget. See our Facebook and Instagram pages for the full range of cars we've transformed.
          </p>
          <div class="hairline my-10"></div>
          <!-- USPs as numbered list -->
          <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-5">
            {usps.map((u, i) => (
              <li class="flex items-start gap-4">
                <span class="font-mono text-[0.7rem] text-muted tracking-wider pt-1.5 w-6 flex-shrink-0">0{i + 1}</span>
                <span>
                  <span class="block font-display font-bold text-navy text-[1.02rem]">{u.title}</span>
                  <span class="block text-muted text-sm leading-snug mt-0.5">{u.body}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: portrait image with subtle frame -->
        <div class="lg:col-span-3 fade-in stagger-3">
          <div class="rounded-2xl overflow-hidden border border-line aspect-[3/4]">
            <img src="/images/about/tj-wrapping.png" alt="TJ Mods wrapping a car at the Ilford workshop" class="w-full h-full object-cover" loading="lazy" width="480" height="640" />
          </div>
          <p class="text-xs font-mono uppercase tracking-wider text-muted mt-3">TJ &amp; the team · Ilford workshop</p>
        </div>
      </div>
    </div>
  </section>

  <!-- §03 — Services (the editorial hover-list, the signature move) -->
  <section class="py-20 md:py-32 section-snow">
    <div class="container-mcp">
      <SectionLead
        num="03"
        kicker="Services"
        title="Seven specialisms, one trusted garage."
        intro="Window tinting, wrapping, PPF, parking sensors, audio, lighting and security - every modification fitted by an experienced team and backed by premium brand partners."
        ctaHref="/services"
        ctaLabel="View all services"
      />
      <div class="mt-14 md:mt-20"><ServiceList /></div>
    </div>
  </section>

  <!-- §04 — Featured editorial moment: real work band -->
  <section class="relative overflow-hidden">
    <div class="featured-band">
      <img src="/images/hero/featured.jpg" alt="Real window tinting work by TJ Mods" class="featured-img" loading="lazy" width="1900" height="1430" />
      <div class="absolute inset-0 hero-overlay"></div>
      <div class="container-mcp relative z-10 py-24 md:py-36">
        <div class="max-w-3xl">
          <p class="section-eyebrow section-eyebrow-light"><span class="section-eyebrow-num">§ 04</span> Real work · Real cars</p>
          <h2 class="text-white text-balance hero-text-shadow" style="font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; line-height: 1.04; letter-spacing: -0.035em;">From a Mercedes Benz through to an Aston Martin.</h2>
          <p class="text-lg text-white/80 leading-relaxed mt-6 max-w-xl hero-text-shadow">15+ years on the same workshop floor in Ilford. See the full portfolio of tints, wraps, PPF, audio, lighting and security.</p>
          <div class="flex flex-col sm:flex-row gap-3 mt-9">
            <a href="/gallery" class="btn btn-light btn-lg">View the gallery <Icon name="ArrowRight" size={15} strokeWidth={2.4} /></a>
            <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-glass btn-lg"><Icon name="MessageCircle" size={17} strokeWidth={2.2} /> WhatsApp us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- §05 — Brand-partner marquee (animated, replaces static grid) -->
  <BrandMarquee />

  <!-- §06 — Gallery preview -->
  <section class="py-20 md:py-32">
    <div class="container-mcp">
      <SectionLead
        num="06"
        kicker="Gallery"
        title="A look at recent work."
        ctaHref="/gallery"
        ctaLabel="See the gallery"
      />
      <div class="flex flex-wrap gap-2 mt-10">
        {galleryCategories.map((c) => (
          <a href={`/gallery/#${encodeURIComponent(c)}`} class="tag !py-2 !px-3.5 text-[0.82rem]">{c}</a>
        ))}
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mt-8">
        {galleryPreview.map((g, i) => (
          <a href="/gallery" class={`gal-shot fade-in stagger-${(i % 4) + 1}`} style={`aspect-ratio: ${i % 3 === 0 ? '4/5' : '1/1'};`}>
            <img src={g.src} alt={g.alt} loading="lazy" width="500" height="500" />
            <span class="gal-cat">{g.category}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- §07 — Google reviews (policy-compliant placeholder + trust) -->
  <ReviewsSection />

  <!-- §08 — Find us -->
  <section class="py-20 md:py-32 section-snow">
    <div class="container-mcp">
      <SectionLead
        num="08"
        kicker="Visit"
        title="225 Green Lane, Ilford."
        intro="Pop in to the East London garage to see our range of films and colours in person."
        align="center"
      />
      <div class="grid lg:grid-cols-5 gap-6 mt-12 items-stretch">
        <div class="lg:col-span-3"><MapBlock height="h-full min-h-[460px]" /></div>
        <div class="lg:col-span-2"><OpeningHours /></div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>

<style>
  .featured-band { position: relative; background: #0F0F0F; }
  .featured-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; }
  .gal-shot { position: relative; display: block; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgb(var(--rgb-border)); background: #0F0F0F; }
  .gal-shot img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.4,0,0.2,1); }
  .gal-shot:hover img { transform: scale(1.07); }
  .gal-cat { position: absolute; left: 0.6rem; bottom: 0.6rem; font-family: var(--font-mono); font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: #fff; background: rgb(15 15 15 / 0.72); padding: 0.25rem 0.55rem; border-radius: 999px; backdrop-filter: blur(6px); opacity: 0; transition: opacity 0.3s ease; }
  .gal-shot:hover .gal-cat { opacity: 1; }
</style>
